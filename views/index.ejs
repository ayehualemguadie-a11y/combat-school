<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combat Technic School</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* 1. የመፈክሩ ከቀኝ ወደ ግራ የመንሸራተቻ እና የ360 ዲግሪ አኒሜሽን ማዘዣ */
        @keyframes moveAndSpinSlogan {
            0% { transform: translateX(100vw) rotate(0deg); text-shadow: 0 0 10px #fbbf24, 0 0 20px #d97706, 2px 2px 5px rgba(0,0,0,0.9); }
            45% { transform: translateX(10vw) rotate(0deg); }
            50% { transform: translateX(0vw) rotate(360deg); text-shadow: 0 0 25px #fbbf24, 0 0 45px #f59e0b, 2px 2px 5px rgba(0,0,0,0.9); }
            55% { transform: translateX(-10vw) rotate(360deg); }
            100% { transform: translateX(-100%) rotate(360deg); text-shadow: 0 0 10px #fbbf24, 0 0 20px #d97706, 2px 2px 5px rgba(0,0,0,0.9); }
        }
        .scrolling-glowing-slogan { animation: moveAndSpinSlogan 15s linear infinite; }

        /* 2. ⚠️ አራቱንም የባነር ፎቶዎች ከቀኝ ወደ ግራ በለስላሳ የሚያሸራትተው አዲሱ አኒሜሽን */
        .slide { display: none; width: 100%; height: 100%; }
        .slide.active { display: block; }
        .slide-left-effect { animation: smoothSlideLeft 1.2s cubic-bezier(0.25, 1, 0.5, 1) forwards; }
        
        @keyframes smoothSlideLeft {
            from { opacity: 0.3; transform: translateX(100%); }
            to { opacity: 1; transform: translateX(0); }
        }

        .dot { height: 11px; width: 11px; background-color: rgba(255,255,255,0.4); border-radius: 50%; display: inline-block; transition: background-color 0.6s ease; }
        .dot.active { background-color: #fbbf24; width: 26px; border-radius: 6px; }

        /* አዲሱ የደማቅ ቀይ አዝራሮች (Red Buttons) ስታይል ማዘዣ */
        .btn-red {
            display: inline-block;
            background-color: #dc2626 !important;
            color: white !important;
            padding: 14px 32px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 900;
            font-size: 16px;
            margin: 10px;
            box-shadow: 0 6px 15px rgba(220, 38, 38, 0.4);
            border: 2px solid transparent;
            transition: all 0.3s ease-in-out;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-red:hover {
            background-color: #b91c1c !important;
            border-color: #fbbf24;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            transform: translateY(-3px);
        }
    </style>
</head>
<body style="background-image: linear-gradient(rgba(0, 0, 0, 0.75), rgba(0, 0, 0, 0.75)), url('/images/ent.jpg') !important; background-size: cover !important; background-position: center !important; background-attachment: fixed !important; background-repeat: no-repeat !important; color: white;">

<!-- 🎖️ የትምህርት ቤቱ መለያ አናት (Header) 🎖️ -->
<header style="position: relative; text-align: center; padding: 25px 10px 20px 10px; background: transparent; color: white; z-index: 5;">
        <!-- 🛡️ ⚠️ ታንኩና መድፉ ሙሉ በሙሉ ጠፍተው የትምህርት ቤቱ ክብ ሎጎ ብቻ መሃል ላይ የቆመበት አዲስ ንጹሕ አሰላለፍ -->
    <div style="text-align: center; margin-bottom: 25px; padding-top: 15px;">
        <div style="display: inline-block; position: relative;">
            <img src="/images/logo.jpg" width="135" style="border-radius: 50%; box-shadow: 0 8px 20px rgba(0,0,0,0.6); border: 3px solid #fbbf24;" alt="Official School Logo">
        </div>
    </div>

    <h1 style="font-size: 38px; font-weight: 800; color: #fbbf24; text-shadow: 2px 2px 6px rgba(0,0,0,0.9); margin: 5px 0 25px 0; letter-spacing: 1px;">
        ውጊያ ቴክኒክ ት/ቤት
    </h1>
    
    <!-- 📌 ተንቀሳቃሽ መፈክር (ከቀኝ ወደ ግራ የሚሄድ) -->
    <div class="slogan-marquee-container" style="margin: 25px auto; max-width: 100%; overflow: hidden; padding: 15px 0; background: rgba(0, 0, 0, 0.2); backdrop-filter: blur(5px); border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
        <span class="scrolling-glowing-slogan" style="font-size: 50px; font-weight: 900; color: #fbbf24; font-style: italic; white-space: nowrap; display: inline-block; letter-spacing: 1px;">
            "እናቅዳለን፤ እንጀምራለን፤ እናሰፋለን፤ በፍጥነት እና በጥራት እንፈጽማለን。"
        </span>
    </div>
</header>

