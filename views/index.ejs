<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combat Technic School</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        /* 1. የመፈክሩ ከቀኝ ወደ ግራ የመንሸራተቻ እና የ360 ዲግሪ አኒሜሽን ማዘዣ */
        @keyframes moveAndSpinSlogan {
            0% { transform: translateX(100vw) rotate(0deg); text-shadow: 0 0 10px #fbbf24, 0 0 20px #d97706, 2px 2px 5px rgba(0,0,0,0.9); }
            45% { transform: translateX(10vw) rotate(0deg); }
            50% { transform: translateX(0vw) rotate(360deg); text-shadow: 0 0 25px #fbbf24, 0 0 45px #f59e0b, 2px 2px 5px rgba(0,0,0,0.9); }
            55% { transform: translateX(-10vw) rotate(360deg); }
            100% { transform: translateX(-100%) rotate(360deg); text-shadow: 0 0 10px #fbbf24, 0 0 20px #d97706, 2px 2px 5px rgba(0,0,0,0.9); }
        }
        .scrolling-glowing-slogan { animation: moveAndSpinSlogan 15s linear infinite; }

        /* 2. ⚠️ አራቱንም የባነር ፎቶዎች ከቀኝ ወደ ግራ በለስላሳ የሚያሸራትተው አዲሱ አኒሜሽን */
        .slide { display: none; width: 100%; height: 100%; }
        .slide.active { display: block; }
        .slide-left-effect { animation: smoothSlideLeft 1.2s cubic-bezier(0.25, 1, 0.5, 1) forwards; }
        
        @keyframes smoothSlideLeft {
            from { opacity: 0.3; transform: translateX(100%); }
            to { opacity: 1; transform: translateX(0); }
        }

        .dot { height: 11px; width: 11px; background-color: rgba(255,255,255,0.4); border-radius: 50%; display: inline-block; transition: background-color 0.6s ease; }
        .dot.active { background-color: #fbbf24; width: 26px; border-radius: 6px; }

        /* አዲሱ የደማቅ ቀይ አዝራሮች (Red Buttons) ስታይል ማዘዣ */
        .btn-red {
            display: inline-block;
            background-color: #dc2626 !important;
            color: white !important;
            padding: 14px 32px;
            text-decoration: none;
            border-radius: 6px;
            font-weight: 900;
            font-size: 16px;
            margin: 10px;
            box-shadow: 0 6px 15px rgba(220, 38, 38, 0.4);
            border: 2px solid transparent;
            transition: all 0.3s ease-in-out;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .btn-red:hover {
            background-color: #b91c1c !important;
            border-color: #fbbf24;
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.4);
            transform: translateY(-3px);
        }
    </style>
</head>
<body>
<!-- 🎖️ የመከላከያ ሎጎ፣ የዋና መግቢያ በር ፎቶ እና የት/ቤት ሎጎ በአንድ ላይ የተቆለፉበት አዲሱ የክብር ራስጌ ክፍል -->
<header style="background: linear-gradient(rgba(17, 24, 39, 0.5), rgba(17, 24, 39, 0.75)), url('/images/gate.jpg') !important; background-size: cover !important; background-position: center 30% !important; background-repeat: no-repeat !important; border-bottom: 4px solid #fbbf24; padding: 25px 40px !important; box-shadow: 0 4px 15px rgba(0,0,0,0.5); position: relative; z-index: 10; max-width: 95% !important; margin: 0 auto !important; border-radius: 0 0 8px 8px;">
    <div style="display: flex; justify-content: space-between; align-items: center; max-width: 1200px; margin: 0 auto; gap: 15px; flex-wrap: nowrap; position: relative; z-index: 12;">
        
        <!-- 🇪🇹 1. በግራ ጫፍ የኢፌድሪ መከላከያ ሠራዊት ሎጎ -->
        <div style="flex: 0 0 auto; text-align: left;">
            <img src="/images/defense-logo.png" 
                 onerror="this.src='/image/defense-logo.png'; this.onerror=function(){this.src='/images/defense-logo.jpg';};" 
                 style="height: 85px !important; width: auto; object-fit: contain; filter: drop-shadow(0 3px 6px rgba(0,0,0,0.8));" 
                 alt="FDRE Defense Force Logo">
        </div>

        <!-- 🏫 2. በመካከላቸው የትምህርት ቤቱ ስምና መፈክር -->
        <div style="flex: 1 1 auto; text-align: center; max-width: 650px;">
            <h1 style="color: #fbbf24; font-size: 26px !important; font-weight: 800; text-shadow: 2px 2px 4px rgba(0,0,0,1); margin: 0; font-family: sans-serif; letter-spacing: 0.5px;">
                የውጊያ ቴክኒክ ትምህርት ቤት
            </h1>
            <p style="color: #ffffff; font-size: 13.5px !important; font-weight: bold; text-shadow: 2px 2px 4px rgba(0,0,0,1); margin: 5px 0 0 0; font-style: italic;">
                "እናቅዳለን፤ እንጀምራለን፤ እናሰፋለን፤ በፍጥነት እና በጥራት እንፈጽማለን。"
            </p>
        </div>

        <!-- 🚜 3. በቀኝ ጫፍ የውጊያ ቴክኒክ ትምህርት ቤት ሎጎ -->
        <div style="flex: 0 0 auto; text-align: right;">
            <img src="/images/logo.png" 
                 onerror="this.src='/image/logo.png'; this.onerror=function(){this.src='/images/logo.jpg';};" 
                 style="height: 85px !important; width: auto; object-fit: contain; filter: drop-shadow(0 3px 6px rgba(0,0,0,0.8));" 
                 alt="Combat Technic School Logo">
        </div>

    </div>
</header>


<!-- 🌐 የተደራረቡት አዝራሮች ተለቅመው የጠፉበት እና ቪዥን ወደ vision.html የተቆለፈበት ንጹሕ ማውጫ (Navbar) -->
