<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combat Technic School</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- 🎖️ የትምህርት ቤቱ ዋና ርዕስ በአማርኛ እና መፈክሩ እንዳለ በክብር ተቆልፏል 🎖️ -->
<header style="text-align: center; padding: 30px 10px 15px 10px; background: transparent; color: white; position: relative; z-index: 5;">
    <img src="/images/logo.jpg" width="120" style="border-radius: 50%; margin-bottom: 15px;" alt="Logo">
    
    <!-- 📌 ዋናው ርዕስ በአማርኛ በትልቅ እና በወርቃማ ቀለም -->
    <h1 style="font-size: 36px; font-weight: 800; color: #fbbf24; text-shadow: 2px 2px 5px rgba(0,0,0,0.9); margin: 0 0 15px 0;">
        ውጊያ ቴክኒክ ት/ቤት
    </h1>
    
    <!-- 📌 መፈክሩ ምንም ሳይነካ ልክ እንደነበረው በክብር እዚህ ተቀምጧል -->
    <div style="display: inline-block; background: rgba(6, 78, 59, 0.6); padding: 12px 20px; border-left: 4px solid #fbbf24; border-right: 4px solid #fbbf24; border-radius: 4px; max-width: 90%; backdrop-filter: blur(5px);">
        <span style="font-size: 16px; font-weight: bold; color: #fff; font-style: italic; text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">
            "እናቅዳለን፤ እንጀምራለን፤ እናሰፋለን፤ በፍጥነት እና በጥራት እንፈጽማለን።"
        </span>
    </div>
</header>


<nav>
    <a href="/">Home</a>
    <a href="/about.html">About</a>
    <a href="/history.html">History</a>
    <a href="https://t.me" target="_blank">Gallery 📸</a>
    <a href="https://t.me" target="_blank">News & Announcements 📰</a>
    <a href="/contact.html">Contact</a>
    <a href="/login.html">Admin</a>
</nav>

<!-- 🖼️ ⚠️ የጀርባ ምስሉ በትክክል እንዲወጣ ክላሱ ወደ hero የተቀየረበት ክፍል -->
<section class="hero">
    <h1>Combat Technic School</h1>
    <p>Training Today's Soldiers for Tomorrow's Mission</p>
    <div style="display: flex; justify-content: center; gap: 15px; margin-top: 20px;">
        <a href="/about.html" class="btn">Learn More</a>
        <a href="/contact.html" class="btn">Contact Us</a>
    </div>
</section>

<!-- 📰 የዜና ማሳያ ክፍል -->
<section class="container">
    <div class="card">
        <h2>📰 Latest News & Announcements</h2>
        <hr style="border:0; border-top:1px solid #eee; margin: 15px 0;">
        <% if (news && news.length > 0) { %>
            <% news.forEach(item => { %>
                <div style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px dashed #eee;">
                    <h3><%= item.title %></h3>
                    <p><%= item.description %></p>
                    <% if (item.image) { %>
                        <br>
                        <img src="<%= item.image %>" style="max-width:100%; height:auto; border-radius:8px; max-height:300px; object-fit:cover;">
                    <% } %>
                    <br>
                    <small style="color: #6b7280;">Posted on: <%= item.created_at %></small>
                </div>
            <% }) %>
        <% } else { %>
            <p align="center" style="color: #6b7280; font-style: italic;">No news or announcements available at the moment.</p>
        <% } %>
    </div>
</section>

<!-- 🛡️ አዲሱ የታንኮች እና የሲሙሌተር መሣሪያዎች ማሳያ ፎቶ -->
<section class="container" style="text-align: center;">
    <div class="card" style="padding: 15px;">
        <h3 style="color: #111827; margin-bottom: 15px;">🎖️ የትምህርት ቤቱ ዘመናዊ የሥልጠና መሣሪያዎች እና ሲሙሌተሮች</h3>
        <img src="/images/military-gear.jpg" style="width: 100%; height: auto; border-radius: 6px; box-shadow: 0 4px 8px rgba(0,0,0,0.15);" alt="Military Equipment">
    </div>
</section>

<!-- 🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ ክፍል -->
<section class="container">
    <div class="card">
        <h2 style="margin-bottom: 20px;">🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ</h2>
        
        <h3 style="color: #0088cc;">👁️ ራዕይ</h3>
        <p style="font-size: 16px; font-weight: 500;">
            በዘመኑ የጥምር ጦር ውጊያ ውስጥ ግዳጃቸውን በላቀ ደረጃ መወጣት የሚችሉ ብቁ የሜካናይዝድና ሞተራይዝድ ሙያተኞችን ማፍራት የሚችል ተመራጭ ት/ቤት ሆኖ ማየት።
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <h3 style="color: #0088cc;">🎯 ተልዕኮ</h3>
        <p style="font-size: 16px; font-weight: 500;">
            በሜካናይዝድና በሞተራይዝድ ሙያ ግዳጃቸውን በብቃት መወጣት የሚችሉ ምድብተኞችን፣ የመሳሪያ አዛዦችን እና የመቶ አመራሮችን ማፍራት፣
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <h3 style="color: #0088cc;">⭐ ዋና ዋና ተግባራት</h3>
        <ul style="list-style-type: none; padding-left: 0; font-size: 15px;">
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 በት/ቤቱ ሥርዓተ-ትምህርት መሰረት ቀጣይነት ያለውና ደረጃውን የጠበቀ የሜካናይዝድ የቴክኒክ ሥልጠና መስጠት Sint-Truiden፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 የፈጠራ ስራዎችን ማከናወንና በቴክኖሎጂ የተደገፈ ሥልጠና መስጠት፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 ለሠራዊታችን ክፍሎች ቀጥተኛ ሙያዊ ድጋፍ በመስጠት የሜካናይዝድ ክፍሎችን የማድረግ አቅም ማሳደግ፣</li>
            <li style="margin-bottom: 5px; padding-left: 20px; text-indent: -20px;">🔹 ከአካባቢው ማህበረሰብ ጋር በፀጥታና በልማት ስራዎች በትብብር መስራት፣</li>
        </ul>
    </div>
</section>

