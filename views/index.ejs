<style>
    /* 📐 መቶ አለቃ፣ ሰራዊቱ ሙሉ በሙሉ እንዲታይ ቁመቱ ወደ 1050px በግዙፉ ያደገ ማዕቀፍ */
    .training-marquee-container {
        position: relative;
        width: 100% !important; 
        max-width: 100% !important; /* ሙሉ ስክሪን ዳርና ዳር እንዲነካ */
        height: 1050px !important; /* 💡 ፎቶው ወደላይ በግዙፉ እንዲረዝም ቁመቱ 1050px ሆኗል! */
        margin: 5px auto !important; /* ወደ ላይ ከፍ ብሎ እንዲቀመጥ */
        overflow: hidden !important;
        border-bottom: 4px solid #fbbf24; /* ወርቃማው የመከላከያ መስመር */
        background-color: #000;
    }

    /* 💡 ፎቶዎቹ በአንድ ረድፍ ተሰልፈው ከግራ ወደ ቀኝ እንዲንቀሳቀሱ display: flex ተደርጓል */
    .training-marquee-track {
        display: flex !important;
        width: max-content !important;
        animation: scrollPhotosLeftToRight 40s linear infinite !important; /* 🏃‍♂️ ከግራ ወደ ቀኝ ማዞሪያ */
    }

    .training-marquee-container:hover .training-marquee-track {
        animation-play-state: paused !important;
    }

    /* 📐 ፎቶዎቹ ሳይንዘረጠሩና ሳይቆረጡ በአንድ መስመር እንዲሰለፉ የተቆለፈበት ልክ */
    .training-photo-item {
        display: inline-block !important;
        position: relative !important;
        width: 1400px !important; /* ሙሉ ስክሪን እንዲሸፍን ስፋቱ ጨምሯል */
        height: 900px !important; /* ሙሉ አካላቸው በግልጽ የሚታይበት ቁመት */
        flex-shrink: 0 !important;
    }

    /* 💡 ፎቶው ሳይቆረጥ በቁመቱ ሙሉ በሙሉ በጥራት እንዲታይ ማድረጊያ */
    .training-photo-item img {
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important; /* ፎቶው እንዳይበላሽ መቆለፊያ */
        object-position: center top !important; /* የሰራዊቱን ራስ ከአናቱ በትክክል ያስተካክላል */
        display: block !important;
    }

    /* ✍️ መፈክሮቹ በጥራት የሚንሳፈፉበት ሳጥን */
    .slogan-overlay-box {
        position: absolute;
        bottom: 80px; /* ፎቶው ሲረዝም ጽሑፉ ይበልጥ ከፍ እንዲል */
        left: 50%;
        transform: translateX(-50%);
        background: rgba(0, 0, 0, 0.75); /* ጥቁር ጥላ */
        padding: 14px 25px;
        border-radius: 8px;
        border-bottom: 4px solid #fbbf24; /* @ወርቃማ መስመር */
        width: 85%;
        text-align: center;
        z-index: 10 !important;
    }

    .slogan-overlay-box h2 {
        color: #ffffff !important;
        font-size: 24px;
        font-weight: bold;
        margin: 0;
        text-shadow: 2px 2px 4px rgba(0,0,0,0.9);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* 🏃‍♂️ ከግራ ወደ ቀኝ ያለምንም ማቋረጥ የሚጓዘው አኒሜሽን ህግ */
    @keyframes scrollPhotosLeftToRight {
        0% { transform: translateX(-50%); }
        100% { transform: translateX(0); }
    }
</style>

<!-- 🎖️ ያንተ ስም ያለበት የግርጌ ማስታወሻ ልክ እንደ ታስክባር ከዳር እስከ ዳር 100% ሙሉ በሙሉ ተዘርግቷል -->
<<!-- ⚠️ ከሳጥን ውጭ ወጥቶ ልክ እንደ ዊንዶውስ ታስክባር 100% ከዳር እስከ ዳር የሚዘረጋ አዲስ የክብር Footer -->
<footer style="background: #111827; color: white; text-align: center; padding: 25px 10px; margin-top: 50px; font-size: 15px; width: 100vw !important; max-width: 100vw !important; position: absolute; left: 50%; transform: translateX(-50%); box-sizing: border-box; z-index: 999; border-radius: 0 !important; box-shadow: none !important;">
    <p>© 2026 Combat Technic School | Developed by Second Lieutenant Ayehualem Guadie</p>
</footer>

<script>
    let currentSlideIndex = 0;
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');

    function showNextSlide() {
        if(slides.length === 0) return;
        slides[currentSlideIndex].classList.remove('active');
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.remove('active');
        
        currentSlideIndex = (currentSlideIndex + 1) % slides.length;
        
        const nextSlide = slides[currentSlideIndex];
        if (nextSlide) {
            nextSlide.style.animation = 'none';
            nextSlide.offsetHeight; 
            nextSlide.style.animation = '';
            nextSlide.classList.add('active');
        }
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.add('active');
    }
    setInterval(showNextSlide, 3000);
</script>
</body>
