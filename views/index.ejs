<!-- 🎡 ⚠️ ዳራውና የፎቶዎቹ የሩጫ መስመር 100% ከዳር እስከ ዳር (Full Width) እንዲዘረጋ የተቆለፈበት አዲስ ክፍል -->
<section class="container-fluid" style="width: 100vw !important; max-width: 100vw !important; padding: 35px 0; overflow: hidden; position: relative; left: 50%; transform: translateX(-50%); box-sizing: border-box; background: linear-gradient(rgba(0,0,0,0.25), rgba(0,0,0,0.25)), url('/images/water.jpg') !important; background-size: cover !important; background-position: center !important; margin: 40px 0;">
    
    <div style="text-align: center; width: 100%;">
        <!-- 📌 ጠንካራ መፈክር በሚዞሩት ፎቶዎች አናት ላይ በትልቅ እና በደመቀ ሮዝ ቀለም -->
        <h2 style="font-size: 36px; font-weight: 800; color: #e11d48; text-shadow: 2px 2px 5px rgba(0,0,0,0.9); margin-bottom: 30px; line-height: 1.4; font-family: sans-serif; padding: 0 20px;">
            "ጠንካራ የሜካናይዝድ ኃይል በመገንባት ዝግጁነታችንን እናረጋግጣለን!"
        </h2>

        <!-- 🏃‍♂️ ⚠️ ከዳር እስከ ዳር ያለምንም መቆራረጥ ፎቶዎቹ የሚሮጡበት ሙሉ ስክሪን መስመር -->
        <div class="training-marquee-container" style="width: 100%; overflow: hidden; position: relative; white-space: nowrap; padding: 15px 0;">
            <div class="training-marquee-track" style="display: inline-block; white-space: nowrap; animation: scrollPhotosLeftToRight 38s linear infinite;">
                
                <!-- 📸 1. መደበኞቹ 4ቱ የሥልጠና ፎቶዎች -->
                <div class="training-photo-item"><img src="/images/photo1.jpg" alt="Training 1"></div>
                <div class="training-photo-item"><img src="/images/photo2.jpg" alt="Training 2"></div>
                <div class="training-photo-item"><img src="/images/photo3.jpg" alt="Training 3"></div>
                <div class="training-photo-item"><img src="/images/photo4.jpg" alt="Training 4"></div>

                <!-- 📸 2. አዲሶቹ የአዋሽ አርባ ፎቶዎች (aw1 - aw6) -->
                <div class="training-photo-item"><img src="/images/aw1.jpg" onerror="this.src='/images/AW1.jpg';" alt="Awash 1"></div>
                <div class="training-photo-item"><img src="/images/aw2.jpg" onerror="this.src='/images/AW2.jpg';" alt="Awash 2"></div>
                <div class="training-photo-item"><img src="/images/aw3.jpg" onerror="this.src='/images/AW3.jpg';" alt="Awash 3"></div>
                <div class="training-photo-item"><img src="/images/aw4.jpg" onerror="this.src='/images/AW4.jpg';" alt="Awash 4"></div>
                <div class="training-photo-item"><img src="/images/aw5.jpg" onerror="this.src='/images/AW5.jpg';" alt="Awash 5"></div>
                <div class="training-photo-item"><img src="/images/aw6.jpg" onerror="this.src='/images/AW6.jpg';" alt="Awash 6"></div>

                <!-- 🔄 3. አኒሜሽኑ ሳያቋርጥ በተከታታይ እንዲዞር የተደገሙ ፎቶዎች (Loop Copy) -->
                <div class="training-photo-item"><img src="/images/photo1.jpg" alt="c1"></div>
                <div class="training-photo-item"><img src="/images/photo2.jpg" alt="c2"></div>
                <div class="training-photo-item"><img src="/images/photo3.jpg" alt="c3"></div>
                <div class="training-photo-item"><img src="/images/photo4.jpg" alt="c4"></div>
                <div class="training-photo-item"><img src="/images/aw1.jpg" alt="c5"></div>
                <div class="training-photo-item"><img src="/images/aw2.jpg" alt="c6"></div>
                <div class="training-photo-item"><img src="/images/aw3.jpg" alt="c7"></div>
                <div class="training-photo-item"><img src="/images/aw4.jpg" alt="c8"></div>
                <div class="training-photo-item"><img src="/images/aw5.jpg" alt="c9"></div>
                <div class="training-photo-item"><img src="/images/aw6.jpg" alt="c10"></div>
            </div>
        </div>
    </div>
</section>



<!-- 💡 የፎቶዎቹን መጠን በግዙፍ ያሳደገው አዲሱ የሲኤስኤስ ስታይል ማዘዣ -->
<style>
    /* 📐 ⚠️ የፎቶዎቹ መጠን እጅግ ማራኪ ሆኖ በትልቁ አድጓል (Width 360px & Height 240px) */
     ⚠️ የፎቶዎቹ መጠን በግድ እጅግ በጣም በትልቁ እንዲያድግ የተቆለፈ አዲስ የሲኤስኤስ ስታይል */
    .training-photo-item {
        display: inline-block !important;
        width: 380px !important; /* 💡 ሳይዙ በጥራት እጅግ በጣም በትልቁ አድጓል */
        height: 250px !important; /* 💡 ቁመቱም በግዙፉ ከፍ ብሏል */
        margin: 0 20px !important;
        overflow: hidden !important;
        border-radius: 12px !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5) !important; /* ጥላው ይበልጥ ደምቋል */
        border: 4px solid #fbbf24 !important; /* ወርቃማው ፍሬም በግልጽ ጎልቷል */
        background-color: #000 !important;
        transition: transform 0.4s ease-in-out !important;
    }
    
    .training-photo-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    /* ማውዙ ሲያርፍበት ፎቶው በጥራት ዙም የማድረግ ውበት */
    .training-photo-item:hover img {
        transform: scale(1.08);
    }

    /* ከግራ ወደ ቀኝ በለስላሳ የሚያሸራትተው አኒሜሽን */
    @keyframes scrollPhotosLeftToRight {
        0% { transform: translateX(-50%); }
        100% { transform: translateX(0); }
    }
    .training-marquee-track { animation: scrollPhotosLeftToRight 35s linear infinite; }
    .training-marquee-container:hover .training-marquee-track { animation-play-state: paused; }
</style>

<!-- 💡 ፎቶዎቹ በአንድ መስመር ከግራ ወደ ቀኝ እንዲንሸራተቱ ማዘዣ (CSS) -->
<style>
    /* 📐 የእያንዳንዱ ፎቶ ስፋትና ቁመት መጠን በጥራት እንዲቀንስ ማድረጊያ */
    .training-photo-item {
        display: inline-block;
        width: 260px; /* ፎቶዎቹ ሙሉ በሙሉ እንዲታዩ መጠናቸው ቀንሷል */
        height: 180px;
        margin: 0 15px;
        overflow: hidden;
        border-radius: 6px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        border: 2px solid #fbbf24; /* ወርቃማ ፍሬም */
    }
    
    .training-photo-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* 🏃‍♂️ ፎቶዎቹን ከግራ ወደ ቀኝ በለስላሳ የሚያሸራትተው ዋናው አኒሜሽን */
    @keyframes scrollPhotosLeftToRight {
        0% {
            transform: translateX(-50%); /* ከግራ በኩል ተንሸራቶ ጉዞ ይጀምራል */
        }
        100% {
            transform: translateX(0); /* ወደ ቀኝ በኩል ያለምንም ማቋረጥ ይጓዛል */
        }
    }

    /* ማውዙ ፎቶው ላይ ሲያርፍ አኒሜሽኑ ለጥቂት ሰከንድ ቆም እንዲል ማድረጊያ ውበት */
    .training-marquee-container:hover .training-marquee-track {
        animation-play-state: paused;
    }
</style>

<!-- 🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ ክፍል -->
<section class="container">
    <div class="card" style="background: white; padding: 25px; margin-top: 25px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border-radius: 6px; border-top: 4px solid #111827;">
        <h2>🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ</h2>
        <hr style="border:0; border-top:1px solid #eee; margin: 15px 0;">
        
        <h3 style="color: #0088cc;">👁️ ራዕይ</h3>
        <p style="font-size: 16px; font-weight: 500; line-height: 1.6;">
            በዘመኑ የጥምር ጦር ውጊያ ውስጥ ግዳጃቸውን በላቀ ደረጃ መወጣት የሚችሉ ብቁ የሜካናይዝድና ሞተራይዝድ ሙያተኞችን ማፍራት የሚችል ተመራጭ ት/ቤት ሆኖ ማየት እንዲሁም በ 2022 ዓ.ም በአፍሪካ 1ኛ እና ተመራጭ የሜካናይዝድ ማሰልጠኛ ተቋም መሆን።
        </p>
        
<        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <!-- 🎯 ተልዕኮ -->
        <h3 style="color: #0088cc;">🎯 ተልዕኮ</h3>
        <p style="font-size: 16px; font-weight: 500; line-height: 1.7; color: #111827;">
            በሜካናይዝድና በሞተራይዝድ ሙያ ግዳጃቸውን በብቃት መወጣት የሚችሉ ምድብተኞችን፣ የመሳሪያ አዛዦችን እና የመቶ አመራሮችን ማፍራት፣
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <!-- ⭐ ዋና ዋና ተግባራት -->
        <h3 style="color: #0088cc;">⭐ ዋና ዋና ተግባራት</h3>
        <ul style="list-style-type: none; padding-left: 0; font-size: 15px; line-height: 1.9; color: #111827;">
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 በት/ቤቱ ሥርዓተ-ትምህርት መሰረት ቀጣይነት ያለውና ደረጃውን የጠበቀ የሜካናይዝድ የቴክኒክ ሥልጠና መስጠት፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 የፈጠራ ስራዎችን ማከናወንና በቴክኖሎጂ የተደገፈ ሥልጠና መስጠት፣</li>
