<!-- 💡 የፎቶዎቹን መጠን በግዙፍ ያሳደገው አዲሱ የሲኤስኤስ ስታይል ማዘዣ -->
<style>
    /* 📐 ⚠️ የፎቶዎቹ መጠን በግድ እጅግ በጣም በትልቁ እንዲያድግና የጀርባውን ምስል እንዲሸፍን የተቆለፈ አዲስ የሲኤስኤስ ስታይል */
    .training-photo-item {
        display: inline-block !important;
        width: 650px !important; /* 💡 ሳይዙ በጥራት እጅግ በጣም በግዙፉ አድጓል (የጀርባውን ምስል ይሸፍናል) */
        height: 420px !important; /* 💡 ቁመቱም በግዙፉ ከፍ ብሏል */
        margin: 0 5px !important; /* 💡 በመካከላቸው ያለውን ክፍተት አጥብበን ሙሉ በሙሉ እንዲሸፍን ማድረግ */
        overflow: hidden !important;
        border-radius: 12px !important;
        box-shadow: 0 10px 25px rgba(0,0,0,0.5) !important; /* ጥላው ይበልጥ ደምቋል */
        border: 4px solid #fbbf24 !important; /* ወርቃማው ፍሬም በግልጽ ጎልቷል */
        background-color: #000 !important;
        transition: transform 0.4s ease-in-out !important;
    }
    
    .training-photo-item img {
        width: 100% !important;
        height: 100% !important;
        object-fit: cover !important;
        transition: transform 0.5s ease !important;
    }

    /* ማውዙ ሲያርፍበት ፎቶው በጥራት ዙም የማድረግ ውበት */
    .training-photo-item:hover img {
        transform: scale(1.08) !important;
    }

    /* 🏃‍♂️ ፎቶዎቹን ከግራ ወደ ቀኝ በጣም በዝግታ (Kess eyale) የሚያሸራትተው ዋናው አኒሜሽን */
    @keyframes scrollPhotosLeftToRight {
        0% { transform: translateX(-50%); }
        100% { transform: translateX(0); }
    }

    /* 🛠️ ፍጥነቱን በጣም ረጋ ለማድረግ ሰከንዱን ከ 35s ወደ 75s አሳድገነዋል (በጣም በዝግታ ይዞራል) */
    .training-marquee-track { 
        animation: scrollPhotosLeftToRight 75s linear infinite !important; 
    }
    
    /* ማውዙ ፎቶው ላይ ሲያርፍ አኒሜሽኑ ለጥቂት ሰከንድ ቆም እንዲል ማድረጊያ ውበት */
    .training-marquee-container:hover .training-marquee-track { 
        animation-play-state: paused !important; 
    }
</style>

<!-- 🎖️ ያንተ ስም ያለበት የግርጌ ማስታወሻ ልክ እንደ ታስክባር ከዳር እስከ ዳር 100% ሙሉ በሙሉ ተዘርግቷል -->
<<!-- ⚠️ ከሳጥን ውጭ ወጥቶ ልክ እንደ ዊንዶውስ ታስክባር 100% ከዳር እስከ ዳር የሚዘረጋ አዲስ የክብር Footer -->
<footer style="background: #111827; color: white; text-align: center; padding: 25px 10px; margin-top: 50px; font-size: 15px; width: 100vw !important; max-width: 100vw !important; position: absolute; left: 50%; transform: translateX(-50%); box-sizing: border-box; z-index: 999; border-radius: 0 !important; box-shadow: none !important;">
    <p>© 2026 Combat Technic School | Developed by Second Lieutenant Ayehualem Guadie</p>
</footer>

<script>
    let currentSlideIndex = 0;
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');

    function showNextSlide() {
        if(slides.length === 0) return;
        slides[currentSlideIndex].classList.remove('active');
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.remove('active');
        
        currentSlideIndex = (currentSlideIndex + 1) % slides.length;
        
        const nextSlide = slides[currentSlideIndex];
        if (nextSlide) {
            nextSlide.style.animation = 'none';
            nextSlide.offsetHeight; 
            nextSlide.style.animation = '';
            nextSlide.classList.add('active');
        }
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.add('active');
    }
    setInterval(showNextSlide, 3000);
</script>
</body>
</html>

