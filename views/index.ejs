<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combat Technic School</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>

<nav class="navbar">
    <div class="logo">
        <img src="/images/logo.jpg" width="65">
        <div>
            <h2>Main Directorate of Defense Education and Training</h2>
            <p>Combat Technic School</p>
        </div>
    </div>

    <ul>
        <li><a href="/">Home</a></li>
        <li><a href="/about.html">About</a></li>
        <li><a href="/history.html">History</a></li>
        <li><a href="/gallery">Gallery</a></li>
        <li><a href="/contact.html">Contact</a></li>
        <li><a href="/login.html">Admin</a></li>
    </ul>
</nav>

<section class="hero">
    <div class="hero-content">
        <h1>Combat Technic School</h1>
        <p>Training Today's Soldiers for Tomorrow's Mission</p>
        <a href="/about.html" class="btn">Learn More</a>
        <a href="/contact.html" class="btn">Contact Us</a>
    </div>
</section>

<!-- 📰 የዜና ማሳያ ክፍል -->
<section class="container">
    <h2 align="center">📰 Latest News & Announcements</h2>
    
    <% if (news && news.length > 0) { %>
        <% news.forEach(item => { %>
            <div class="card" style="margin-bottom: 20px;">
                <h3><%= item.title %></h3>
                <p><%= item.description %></p>
                <% if (item.image) { %>
                    <br>
                    <img src="/images/<%= item.image %>" style="max-width:100%; height:auto; border-radius:8px; max-height:300px; object-fit:cover;">
                <% } %>
                <br><br>
                <small style="color: #666;">Posted on: <%= item.created_at %></small>
            </div>
        <% }) %>
    <% } else { %>
        <div class="card">
            <p align="center" style="color: #666;">No news or announcements available at the moment.</p>
        </div>
    <% } %>
</section>

<section class="container">
    <div class="card">
        <h2>Welcome</h2>
        <p>
            Combat Technic School is committed to providing high-quality
            technical and military training using experienced instructors,
            modern equipment, and practical exercises.
        </p>
    </div>
</section>

<!-- 📞 የተስተካከለው የመገናኛ መረጃ (Contact Information) ክፍል እዚህ ጋር ነው 📞 -->
<!-- 📞 የተስተካከለው የመገናኛ መረጃ ከቴሌግራም ሊንክ ጋር 📞 -->
<!-- 🔗 ስትነካው ቀጥታ ወደ ቴሌግራም ቻናሉ የሚወስደው እውነተኛው አዝራር 🔗 -->
<section class="container">
    <h2 align="center">📞 Contact Information</h2>
    <div class="card" style="max-width: 600px; margin: 0 auto; padding: 30px; text-align: center; line-height: 1.8;">
        <h3 style="margin-bottom: 10px; color: #111827;">Combat Technic School</h3>
        <p style="color: #666; margin-bottom: 20px;">Location: Awash Arba, Ethiopia</p>
        
        <p style="font-size: 16px; margin-bottom: 20px;">
            For all official school news, announcements, photo galleries, and updates, please join our official Telegram channel.
        </p>
        
        <!-- 📢 የቴሌግራም ሙሉ ሊንኩ እዚህ ጋር በግልጽ href ውስጥ ገብቷል -->
        <a href="https://t.me" target="_blank" style="display: inline-block; padding: 12px 25px; background: #0088cc; color: white; text-decoration: none; border-radius: 5px; font-weight: bold; font-size: 16px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
            Join Our Official Telegram Channel 📸 📰
        </a>
    </div>
</section>


<section class="container">
    <h2 align="center">Why Choose Us?</h2>
    <div class="card">
        <h3>✔ Professional Training</h3>
        <p>Experienced instructors with practical military knowledge.</p>
        <hr>
        <h3>✔ Modern Equipment</h3>
        <p>Training with modern technology and equipment.</p>
        <hr>
        <h3>✔ Practical Exercises</h3>
        <p>Hands-on training to prepare students for real missions.</p>
        <hr>
        <h3>✔ Discipline & Leadership</h3>
        <p>Building leadership, discipline, and teamwork.</p>
    </div>
</section>

<footer style="background:#111827;color:white;text-align:center;padding:30px;margin-top:40px;">
    <p>© 2026 Combat Technic School</p>
</footer>

</body>
</html>
