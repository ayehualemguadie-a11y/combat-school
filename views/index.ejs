<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combat Technic School</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- 🎖️ የታንክና መድፍ መጠን አድጎ፣ መፈክሩና ፎቶዎቹ 360 ዲግሪ የሚሽከረከሩበት ዋናው ባነር ክፍል 🎖️ -->
<header style="position: relative; text-align: center; padding: 25px 10px 20px 10px; background: transparent; color: white; z-index: 5;">
    
    <!-- 🖼️ የራሳችን አርማ አሰላለፍ (T-72 ታንክ፣ ሎጎ እና 155 ሚ.ሜ መድፍ) -->
    <div style="display: flex; justify-content: center; align-items: flex-end; gap: 40px; margin-bottom: 25px; max-width: 95%; margin-left: auto; margin-right: auto; padding-top: 10px;">
        <!-- 🚜 የራሳችን T-72 ታንክ -->
        <div style="display: inline-block; margin-bottom: -15px;">
            <img src="/images/t72.jpg" style="width: 200px; height: 135px; object-fit: cover; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.6); border: 3px solid #fbbf24;" alt="T-72 Tank">
        </div>
        <!-- 🛡️ የራሳችን ክብ ሎጎ -->
        <div style="display: flex; align-items: center; margin-bottom: 25px;">
            <img src="/images/logo.jpg" width="130" style="border-radius: 50%; box-shadow: 0 6px 12px rgba(0,0,0,0.4);" alt="Logo">
        </div>
        <!-- 💥 የራሳችን 155 ሚ.ሜ መድፍ -->
        <div style="display: inline-block; margin-bottom: -15px;">
            <img src="/images/medif155.jpg" style="width: 200px; height: 135px; object-fit: cover; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.5); border: 3px solid #fbbf24;" alt="155mm Artillery">
        </div>
    </div>

    <!-- 📌 የራሳችን ዋና ርዕስ በወርቃማ ቀለም -->
    <h1 style="font-size: 38px; font-weight: 800; color: #fbbf24; text-shadow: 2px 2px 6px rgba(0,0,0,0.9); margin: 5px 0 25px 0; letter-spacing: 1px;">
        ውጊያ ቴክኒክ ት/ቤት
    </h1>
    
    <!-- 📌 ⚠️ ታላቁ መፈክር ከቀኝ ወደ ግራ እየተንቀሳቀሰ 360 ዲግሪ በሚሽከረከር አኒሜሽን ተቆልፏል -->
    <div class="slogan-marquee-container" style="margin: 25px auto; max-width: 100%; overflow: hidden; padding: 15px 0; background: rgba(0, 0, 0, 0.2); backdrop-filter: blur(5px); border-top: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
        <span class="scrolling-glowing-slogan" style="font-size: 50px; font-weight: 900; color: #fbbf24; font-style: italic; white-space: nowrap; display: inline-block; letter-spacing: 1px;">
            "እናቅዳለን፤ እንጀምራለን፤ እናሰፋለን፤ በፍጥነት እና በጥራት እንፈጽማለን。"
        </span>
    </div>

    <!-- 🎡 ⚠️ አራቱ ፎቶዎች በየተራ 360 ዲግሪ እየተሽከረከሩ እንዲመጡ የተቆለፈበት አዲስ ሳጥን -->
    <div class="slider-container" style="position: relative; max-width: 600px; height: 550px; margin: 30px auto 10px auto; overflow: hidden; border-radius: 12px; box-shadow: 0 12px 30px rgba(0,0,0,0.5); border: 4px solid rgba(255,255,255,0.2); background-color: transparent;">
        
        <!-- 📸 ⚠️ ፎቶዎቹ 360 ዲግሪ እንዲዞሩ spin-effect የሚለው አዲሱ አኒሜሽን ገብቶባቸዋል -->
        <div class="slide spin-effect active"><img src="/images/photo1.jpg" style="width:100%; height:150%; object-fit: fill;" alt="Our Slide 1"></div>
        <div class="slide spin-effect"><img src="/images/photo2.jpg" style="width:100%; height:150%; object-fit: fill;" alt="Our Slide 2"></div>
        <div class="slide spin-effect"><img src="/images/photo3.jpg" style="width:100%; height:150%; object-fit: fill;" alt="Our Slide 3"></div>
        <div class="slide spin-effect"><img src="/images/photo4.jpg" style="width:100%; height:150%; object-fit: fill;" alt="Our Slide 4"></div>

        <!-- 👇 የ 4ቱ ፎቶዎች ጠቋሚ ነጥቦች -->
        <div style="position: absolute; bottom: 18px; left: 50%; transform: translateX(-50%); display: flex; gap: 8px; z-index: 10;">
            <span class="dot active"></span>
            <span class="dot"></span>
            <span class="dot"></span>
            <span class="dot"></span>
        </div>
    </div>

    <!-- 💡 የሰላይደሩ እና የመፈክሩ አጠቃላይ የአኒሜሽን ማዘዣ (CSS Styles) -->
    <style>
        /* 1. የመፈክሩ የግራና ቀኝ የ360 ዲግሪ አኒሜሽን ማዘዣ */
        @keyframes moveAndSpinSlogan {
            0% { transform: translateX(100vw) rotate(0deg); text-shadow: 0 0 10px #fbbf24, 0 0 20px #d97706, 2px 2px 5px rgba(0,0,0,0.9); }
            45% { transform: translateX(10vw) rotate(0deg); }
            50% { transform: translateX(0vw) rotate(360deg); text-shadow: 0 0 25px #fbbf24, 0 0 45px #f59e0b, 2px 2px 5px rgba(0,0,0,0.9); }
            55% { transform: translateX(-10vw) rotate(360deg); }
            100% { transform: translateX(-100%) rotate(360deg); text-shadow: 0 0 10px #fbbf24, 0 0 20px #d97706, 2px 2px 5px rgba(0,0,0,0.9); }
        }
        .scrolling-glowing-slogan { animation: moveAndSpinSlogan 15s linear infinite; }

        /* 2. አራቱንም ፎቶዎች በየተራ 360 ዲግሪ የሚያሽከረክረው አዲሱ አኒሜሽን */
        .slide { display: none; width: 100%; height: 100%; }
        .slide.active { display: block; }
        .spin-effect { animation: photo360Spin 1.2s cubic-bezier(0.4, 0, 0.2, 1) forwards; }
        
        @keyframes photo360Spin {
            from { opacity: 0.2; transform: scale(0.3) rotate(0deg); }
            to { opacity: 1; transform: scale(1) rotate(360deg); }
        }

        .dot { height: 11px; width: 11px; background-color: rgba(255,255,255,0.4); border-radius: 50%; display: inline-block; transition: background-color 0.6s ease; }
        .dot.active { background-color: #fbbf24; width: 26px; border-radius: 6px; }
    </style>

    <!-- 💡 በየ 3 ሰከንዱ ፎቶዎቹን እያዞረ የሚቀያይረው ጃቫስክሪፕት (JavaScript Logic) -->
    <script>
        let currentSlideIndex = 0;
        const slides = document.querySelectorAll('.slide');
        const dots = document.querySelectorAll('.dot');

        function showNextSlide() {
            slides[currentSlideIndex].classList.remove('active');
            dots[currentSlideIndex].classList.remove('active');

            currentSlideIndex = (currentSlideIndex + 1) % slides.length;

            const nextSlide = slides[currentSlideIndex];
            nextSlide.style.animation = 'none';
            nextSlide.offsetHeight; 
            nextSlide.style.animation = '';

            nextSlide.classList.add('active');
            dots[currentSlideIndex].classList.add('active');
        }

        setInterval(showNextSlide, 3000);
    </script>
</header>

<!-- 🌐 ውቡ ሰማያዊ ማውጫ (Navbar) -->
<nav>
    <a href="/">Home</a>
    <a href="/about.html">About</a>
    <a href="/history.html">History</a>
    <a href="https://t.me" target="_blank">Gallery 📸</a>
    <a href="https://t.me" target="_blank">News & Announcements 📰</a>
    <a href="/contact.html">Contact</a>
    <a href="/login.html">Admin</a>
</nav>

<!-- 🖼️ የጀርባ ምስሉን እና የፊቱን ጽሑፍ የያዘው የጀግናው ክፍል -->
<section class="hero">
    <h1 style="font-size: 38px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8); margin-bottom: 10px;">Combat Technic School</h1>
    <p style="font-size: 18px; text-shadow: 1px 1px 3px rgba(0,0,0,0.6); margin-bottom: 25px;">Training Today's Soldiers for Tomorrow's Mission</p>
    <div style="display: flex; justify-content: center; gap: 15px;">
        <a href="/about.html" class="btn">Learn More</a>
        <a href="/contact.html" class="btn" style="background-color: #111827;">Contact Us</a>
    </div>
</section>

<!-- 📰 የዜና ማሳያ ክፍል -->
<section class="container">
    <div class="card">
        <h2>📰 Latest News & Announcements</h2>
        <hr style="border:0; border-top:1px solid #eee; margin: 15px 0;">
        <% if (news && news.length > 0) { %>
            <% news.forEach(item => { %>
                <div style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px dashed #eee;">
                    <h3><%= item.title %></h3>
                    <p><%= item.description %></p>
                    <% if (item.image) { %>
                        <br>
                        <img src="<%= item.image %>" style="max-width:100%; height:auto; border-radius:8px; max-height:300px; object-fit:cover;">
                    <% } %>
                    <br>
                    <small style="color: #6b7280;">Posted on: <%= item.created_at %></small>
                </div>
            <% }) %>
        <% } else { %>
            <p align="center" style="color: #6b7280; font-style: italic;">No news or announcements available at the moment.</p>
        <% } %>
    </div>
</section>

<!-- 🛡️ አዲሱ የታንኮች እና የሲሙሌተር መሣሪያዎች ማሳያ ፎቶ -->
<section class="container" style="text-align: center;">
    <div class="card" style="padding: 15px;">
        <h3 style="color: #111827; margin-bottom: 15px;">🎖️ የትምህርት ቤቱ ዘመናዊ የሥልጠና መሣሪያዎች እና ሲሙሌተሮች</h3>
        <img src="/images/military-gear.jpg" style="width: 100%; height: auto; border-radius: 6px; box-shadow: 0 4px 8px rgba(0,0,0,0.15);" alt="Military Equipment">
    </div>
</section>

<!-- 🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ ክፍል -->
<section class="container">
    <div class="card">
        <h2 style="margin-bottom: 20px;">🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ</h2>
        
        <h3 style="color: #0088cc;">👁️ ራዕይ</h3>
        <p style="font-size: 16px; font-weight: 500;">
            በዘመኑ የጥምር ጦር ውጊያ ውስጥ ግዳጃቸውን በላቀ ደረጃ መወጣት የሚችሉ ብቁ የሜካናይዝድና ሞተራይዝድ ሙያተኞችን ማፍራት የሚችል ተመራጭ ት/ቤት ሆኖ ማየት እንዲሁም በ 2022 ዓ.ም በአፍሪካ 1ኛ እና ተመራጭ የሜካናይዝድ ማሰልጠኛ ተቋም መሆን።
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <h3 style="color: #0088cc;">🎯 ተልዕኮ</h3>
        <p style="font-size: 16px; font-weight: 500;">
            በሜካናይዝድና በሞተራይዝድ ሙያ ግዳጃቸውን በብቃት መወጣት የሚችሉ ምድብተኞችን፣ የመሳሪያ አዛዦችን እና የመቶ አመራሮችን ማፍራት፣
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <h3 style="color: #0088cc;">⭐ ዋና ዋና ተግባራት</h3>
        <ul style="list-style-type: none; padding-left: 0; font-size: 15px;">
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 በት/ቤቱ ሥርዓተ-ትምህርት መሰረት ቀጣይነት ያለውና ደረጃውን የጠበቀ የሜካናይዝድ የቴክኒክ ሥልጠና መስጠት፣</li>
