</style>


<!-- 🎡 ⚠️ ዳራውና የፎቶዎቹ የሩጫ መስመር 100% ከዳር እስከ ዳር (Full Width) እንዲዘረጋ የተቆለፈበት አዲስ ክፍል -->
<section class="container-fluid" style="width: 100vw !important; max-width: 100vw !important; padding: 35px 0; overflow: hidden; position: relative; left: 50%; transform: translateX(-50%); box-sizing: border-box; background: linear-gradient(rgba(0,0,0,0.25), rgba(0,0,0,0.25)), url('/images/water.jpg') !important; background-size: cover !important; background-position: center !important; margin: 40px 0;">
    
    <div style="text-align: center; width: 100%;">
        <!-- 📌 ጠንካራ መፈክር በሚዞሩት ፎቶዎች አናት ላይ በትልቅ እና በደመቀ ሮዝ ቀለም -->
        <h2 style="font-size: 36px; font-weight: 800; color: #e11d48; text-shadow: 2px 2px 5px rgba(0,0,0,0.9); margin-bottom: 30px; line-height: 1.4; font-family: sans-serif; padding: 0 20px;">
            "ጠንካራ የሜካናይዝድ ኃይል በመገንባት ዝግጁነታችንን እናረጋግጣለን!"
        </h2>

      <div class="training-marquee-container">
    <!-- መፈክሩ በፎቶዎቹ ላይ በግልጽ እንዲታይ ከላይ ተቀምጧል -->
    <!-- 🛠️ መቶ አለቃ፣ ይህንን የጽሑፍ መስመር ከኮዱ ውስጥ ፈልገው ሙሉ በሙሉ ያጥፉት -->
<div class="slogan-overlay">
    <h2>«ስልጠናችንን በማዘመን ተዋግቶ የሚያሸንፍ የሜካናይዝድ ሃይል እናፈራለን!»</h2>
</div>


    <!-- 💡 መቶ አለቃ፣ አዲሶቹ H1 እስከ H6 ፎቶዎች እዚህ ገብተዋል -->
    <div class="training-photo-item"><img src="images/H1.jpg" alt="ስልጠና 1"></div>
    <div class="training-photo-item"><img src="images/H2.jpg" alt="ስልጠና 2"></div>
    <div class="training-photo-item"><img src="images/H3.jpg" alt="ስልጠና 3"></div>
    <div class="training-photo-item"><img src="images/H4.jpg" alt="ስልጠና 4"></div>
    <div class="training-photo-item"><img src="images/H5.jpg" alt="ስልጠና 5"></div>
    <div class="training-photo-item"><img src="images/H6.jpg" alt="ስልጠና 6"></div>
</div>

</section>
<style>
  <style>
    /* 📐 መቶ አለቃ፣ ፎቶዎቹ ሳይቆረጡና ሳይለጠጡ በትክክለኛው መጠን እንዲቀመጡ የተደረገ ማዕቀፍ */
    .training-marquee-container {
        position: relative;
        width: 100% !important; 
        max-width: 100% !important; /* ሙሉ ስክሪን ዳርና ዳር ይነካል */
        height: 500px !important; /* ሚዛናዊ የሆነና ለፎቶዎቹ ተስማሚ ቁመት */
        margin: 0 auto !important;
        overflow: hidden;
        border-bottom: 4px solid #fbbf24; /* ወርቃማው የመከላከያ መስመር */
        background-color: #000;
    }

    /* ሁሉንም 6 ፎቶዎች አንድ ቦታ ላይ ደራርቦ 100% ሙሉ ለማድረግ */
    .training-photo-item {
        position: absolute;
        top: 0;
        left: 0;
        width: 100% !important;
        height: 100% !important;
        opacity: 0;
        z-index: 1;
        /* 💡 ፎቶው ሲቀየር ያለምንም መቆራረጥ ለስላሳ እንዲሆን */
        transition: opacity 1s ease-in-out; 
    }

        /* 💡 መቶ አለቃ፣ ፎቶው እንዳይቆረጥና ሙሉ አካሉ በግልጽ እንዲታይ የተደረገበት ማዘዣ */
      /* 💡 መቶ አለቃ፣ ፎቶው ሳይቆረጥና ሳይለጠጥ በተፈጥሮ ቅርጹ በጥራት እንዲታይ ማድረጊያ */
    .training-photo-item img {
        width: 100% !important;
        height: 100% !important;
        object-fit: contain !important; /* 💡 ፎቶው ሳይቆረጥና ሳይለጠጥ በኦሪጅናል ቅርጹ በጥራት ያስቀምጠዋል */
        object-position: center center !important; /* ፎቶውን መሃል ለመሃል ያደርገዋል */
    }


    /* 🏃‍♂️ 💡 መቶ አለቃ፣ መዘግየትን ለማስቀረት ጠቅላላ የዙር ጊዜውን ወደ 24s አሳጥረነዋል (እያንዳንዱ ፎቶ 4 ሰከንድ ይታያል) */
    .training-photo-item:nth-child(1) { animation: etduPureFadeAnimation 24s infinite; animation-delay: 0s; }
    .training-photo-item:nth-child(2) { animation: etduPureFadeAnimation 24s infinite; animation-delay: 4s; }
    .training-photo-item:nth-child(3) { animation: etduPureFadeAnimation 24s infinite; animation-delay: 8s; }
    .training-photo-item:nth-child(4) { animation: etduPureFadeAnimation 24s infinite; animation-delay: 12s; }
    .training-photo-item:nth-child(5) { animation: etduPureFadeAnimation 24s infinite; animation-delay: 16s; }
    .training-photo-item:nth-child(6) { animation: etduPureFadeAnimation 24s infinite; animation-infinite-delay: 20s; }

    /* 💡 ከልክ በላይ ዙም ሆኖ መለጠጥን ለማስቀረት scale() ሙሉ በሙሉ ተወግዷል (Pure Smooth Fade) */
    @keyframes etduPureFadeAnimation {
        0% {
            opacity: 0;
        }
        /* ፎቶው እንደገባ ወዲያውኑ በ 0.5 ሰከንድ ውስጥ ፍንትው ብሎ ይበራል */
        2% {
            opacity: 1;
            z-index: 2;
        }
        /* ፎቶው በጥራት ያለምንም ዙም ለ 4 ሰከንዶች ጸንቶ ይቆማል */
        16.66% {
            opacity: 1;
            z-index: 2;
        }
        /* ቀስ ብሎ በዝግታ እየጠፋ ለቀጣዩ ፎቶ ቦታ ይለቃል */
        20.66% {
            opacity: 0;
            z-index: 1;
        }
        100% {
            opacity: 0;
            z-index: 1;
        }
    }

    /* ማውሱ ፎቶው ላይ ሲያርፍ አኒሜሽኑ ለጥቂት ሰከንድ ቆም እንዲል ማድረጊያ */
    .training-marquee-container:hover .training-photo-item {
        animation-play-state: paused;
    }
</style>


<!-- 🎖️ ያንተ ስም ያለበት የግርጌ ማስታወሻ ልክ እንደ ታስክባር ከዳር እስከ ዳር 100% ሙሉ በሙሉ ተዘርግቷል -->
<<!-- ⚠️ ከሳጥን ውጭ ወጥቶ ልክ እንደ ዊንዶውስ ታስክባር 100% ከዳር እስከ ዳር የሚዘረጋ አዲስ የክብር Footer -->
<footer style="background: #111827; color: white; text-align: center; padding: 25px 10px; margin-top: 50px; font-size: 15px; width: 100vw !important; max-width: 100vw !important; position: absolute; left: 50%; transform: translateX(-50%); box-sizing: border-box; z-index: 999; border-radius: 0 !important; box-shadow: none !important;">
    <p>© 2026 Combat Technic School | Developed by Second Lieutenant Ayehualem Guadie</p>
</footer>

<script>
    let currentSlideIndex = 0;
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');

    function showNextSlide() {
        if(slides.length === 0) return;
        slides[currentSlideIndex].classList.remove('active');
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.remove('active');
        
        currentSlideIndex = (currentSlideIndex + 1) % slides.length;
        
        const nextSlide = slides[currentSlideIndex];
        if (nextSlide) {
            nextSlide.style.animation = 'none';
            nextSlide.offsetHeight; 
            nextSlide.style.animation = '';
            nextSlide.classList.add('active');
        }
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.add('active');
    }
    setInterval(showNextSlide, 3000);
</script>
</body>
</html>

