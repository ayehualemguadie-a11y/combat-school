<!-- Hero Section -->

<!-- 📰 Latest News Section (EJS ስህተት ሙሉ በሙሉ የጸዳበት አስተማማኝ መዋቅር) -->
<!-- 🎡 ⚠️ አራቱ የሥልጠና ፎቶዎች ባሉበት መስመር ከግራ ወደ ቀኝ እንዲንሸራተቱ የተቆለፈበት አዲስ ክፍል -->
<!-- 🎡 አራቱ ፎቶዎች ከግራ ወደ ቀኝ የሚዞሩበት እና መፈክሩ አናት ላይ በወርቃማ ቀለም የገባበት ክፍል -->
<!-- 🎡 አራቱ ፎቶዎች ባሉበት መስመር ከግራ ወደ ቀኝ እንዲንቀሳቀሱ አኒሜሽኑ እንደገና የተቆለፈበት ክፍል -->
<section class="container" style="text-align: center; overflow: hidden; padding: 25px 10px;">
    <div class="card" style="padding: 20px; background: transparent !important; box-shadow: none !important; border: none !important; overflow: hidden; position: relative;">
        
        <!-- 📌 ⚠️ መፈክሩ ይበልጥ ጎልቶ እንዲታይ ወደ ደማቅ ሮዝ ቀለም (Pink/Magenta) የተቀየረበት አዲስ መስመር -->
<h2 style="font-size: 34px; font-weight: 800; color: #e11d48; text-shadow: 2px 2px 5px rgba(0,0,0,0.8); margin-bottom: 25px; line-height: 1.4; font-family: sans-serif;">
    "ጠንካራ የሜካናይዝድ ኃይል በመገንባት ዝግጁነታችንን እናረጋግጣለን!"
</h2>

        <!-- 🏃‍♂️ ⚠️ ፎቶዎቹ ከግራ ወደ ቀኝ መሮጣቸውን እንዲቀጥሉ animation ትዕዛዝ በውስጡ የተቆለፈበት ዋና መስመር -->
        <div class="training-marquee-container" style="width: 100%; overflow: hidden; position: relative; white-space: nowrap; padding: 10px 0;">
            <div class="training-marquee-track" style="display: inline-block; white-space: nowrap; animation: scrollPhotosLeftToRight 20s linear infinite;">
                
                <!-- 📸 4ቱ የራሳችን ወታደራዊ ፎቶዎች -->
                <div class="training-photo-item"><img src="/images/photo1.jpg" alt="Training 1"></div>
                <div class="training-photo-item"><img src="/images/photo2.jpg" alt="Training 2"></div>
                <div class="training-photo-item"><img src="/images/photo3.jpg" alt="Training 3"></div>
                <div class="training-photo-item"><img src="/images/photo4.jpg" alt="Training 4"></div>

                <!-- 🔄 ለቀጣይነት ያለው ሩጫ የተደገፉ ፎቶዎች (Loop Copy) -->
                <div class="training-photo-item"><img src="/images/photo1.jpg" alt="Copy 1"></div>
                <div class="training-photo-item"><img src="/images/photo2.jpg" alt="Copy 2"></div>
                <div class="training-photo-item"><img src="/images/photo3.jpg" alt="Copy 3"></div>
                <div class="training-photo-item"><img src="/images/photo4.jpg" alt="Copy 4"></div>
            </div>
        </div>

    </div>
</section>

<!-- 💡 ፎቶዎቹ በአንድ መስመር ከግራ ወደ ቀኝ እንዲንሸራተቱ ማዘዣ (CSS) -->
<style>
    /* 📐 የእያንዳንዱ ፎቶ ስፋትና ቁመት መጠን በጥራት እንዲቀንስ ማድረጊያ */
    .training-photo-item {
        display: inline-block;
        width: 260px; /* ፎቶዎቹ ሙሉ በሙሉ እንዲታዩ መጠናቸው ቀንሷል */
        height: 180px;
        margin: 0 15px;
        overflow: hidden;
        border-radius: 6px;
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
        border: 2px solid #fbbf24; /* ወርቃማ ፍሬም */
    }
    
    .training-photo-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* 🏃‍♂️ ፎቶዎቹን ከግራ ወደ ቀኝ በለስላሳ የሚያሸራትተው ዋናው አኒሜሽን */
    @keyframes scrollPhotosLeftToRight {
        0% {
            transform: translateX(-50%); /* ከግራ በኩል ተንሸራቶ ጉዞ ይጀምራል */
        }
        100% {
            transform: translateX(0); /* ወደ ቀኝ በኩል ያለምንም ማቋረጥ ይጓዛል */
        }
    }

    /* ማውዙ ፎቶው ላይ ሲያርፍ አኒሜሽኑ ለጥቂት ሰከንድ ቆም እንዲል ማድረጊያ ውበት */
    .training-marquee-container:hover .training-marquee-track {
        animation-play-state: paused;
    }
</style>

<!-- 🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ ክፍል -->
<section class="container">
    <div class="card" style="background: white; padding: 25px; margin-top: 25px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); border-radius: 6px; border-top: 4px solid #111827;">
        <h2>🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ</h2>
        <hr style="border:0; border-top:1px solid #eee; margin: 15px 0;">
        
        <h3 style="color: #0088cc;">👁️ ራዕይ</h3>
        <p style="font-size: 16px; font-weight: 500; line-height: 1.6;">
            በዘመኑ የጥምር ጦር ውጊያ ውስጥ ግዳጃቸውን በላቀ ደረጃ መወጣት የሚችሉ ብቁ የሜካናይዝድና ሞተራይዝድ ሙያተኞችን ማፍራት የሚችል ተመራጭ ት/ቤት ሆኖ ማየት እንዲሁም በ 2022 ዓ.ም በአፍሪካ 1ኛ እና ተመራጭ የሜካናይዝድ ማሰልጠኛ ተቋም መሆን።
        </p>
        
<        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <!-- 🎯 ተልዕኮ -->
        <h3 style="color: #0088cc;">🎯 ተልዕኮ</h3>
        <p style="font-size: 16px; font-weight: 500; line-height: 1.7; color: #111827;">
            በሜካናይዝድና በሞተራይዝድ ሙያ ግዳጃቸውን በብቃት መወጣት የሚችሉ ምድብተኞችን፣ የመሳሪያ አዛዦችን እና የመቶ አመራሮችን ማፍራት፣
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <!-- ⭐ ዋና ዋና ተግባራት -->
        <h3 style="color: #0088cc;">⭐ ዋና ዋና ተግባራት</h3>
        <ul style="list-style-type: none; padding-left: 0; font-size: 15px; line-height: 1.9; color: #111827;">
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 በት/ቤቱ ሥርዓተ-ትምህርት መሰረት ቀጣይነት ያለውና ደረጃውን የጠበቀ የሜካናይዝድ የቴክኒክ ሥልጠና መስጠት፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 የፈጠራ ስራዎችን ማከናወንና በቴክኖሎጂ የተደገፈ ሥልጠና መስጠት፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 ለሠራዊታችን ክፍሎች ቀጥተኛ ሙያዊ ድጋፍ በመስጠት የሜካናይዝድ ክፍሎችን የማድረግ አቅም ማሳደግ፣</li>
            <li style="margin-bottom: 5px; padding-left: 20px; text-indent: -20px;">🔹 ከአካባቢው ማህበረሰብ ጋር በፀጥታና በልማት ስራዎች በትብብር መስራት፣</li>
        </ul>
<!-- 🎖️ ያንተን ስም የያዘው የክብር ግርጌ ማስታወሻ (Footer) እዚህ ተመልሷል -->
<!-- 🎖️ ያንተ ስም ያለበት የግርጌ ማስታወሻ ስፋቱ አጥሮ ከመሃል ሳጥን ጋር እኩል ተደርጓል -->
<<!-- 🎖️ ያንተ ስም ያለበት የግርጌ ማስታወሻ ስፋቱ አጥሮ ከመሃል ሳጥን ጋር እኩል ተደርጓል -->
<<!-- 🎖️ ያንተ ስም ያለበት የግርጌ ማስታወሻ ልክ እንደ ታስክባር ከዳር እስከ ዳር 100% ሙሉ በሙሉ ተዘርግቷል -->
<footer style="background: #111827; color: white; text-align: center; padding: 25px 10px; margin-top: 50px; font-size: 15px; width: 100% !important; max-width: 100% !important; position: relative; left: 0; right: 0; box-sizing: border-box;">
    <p>© 2026 Combat Technic School | Developed by Second Lieutenant Ayehualem Guadie</p>
</footer>
<script>
    let currentSlideIndex = 0;
    const slides = document.querySelectorAll('.slide');
    const dots = document.querySelectorAll('.dot');

    function showNextSlide() {
        if(slides.length === 0) return;
        slides[currentSlideIndex].classList.remove('active');
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.remove('active');
        
        currentSlideIndex = (currentSlideIndex + 1) % slides.length;
        
        const nextSlide = slides[currentSlideIndex];
        nextSlide.style.animation = 'none';
        nextSlide.offsetHeight; 
        nextSlide.style.animation = '';
        
        nextSlide.classList.add('active');
        if(dots.length > currentSlideIndex) dots[currentSlideIndex].classList.add('active');
    }
    setInterval(showNextSlide, 3000);
</script>
</body>
