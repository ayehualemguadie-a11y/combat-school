<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Combat Technic School</title>
    <link rel="stylesheet" href="/style.css">
</head>
<body>

<!-- 🎖️ የትምህርት ቤቱ መለያ ባነር ክፍል -->
<!-- 🎖️ የታንኩና የመድፉ መጠን አድጎ ወደ ታች ዝቅ የተደረገበት ፍጹም Header 🎖️ -->
<header style="position: relative; text-align: center; padding: 15px 10px 5px 10px; background: transparent; color: white; z-index: 5;">
    
    <!-- 🖼️ ሎጎውን መሃል አድርጎ ታንኩንና መድፉን በትልቁ ወደ ታች ዝቅ አድርጎ የሚያሰልፍ ዋና ሳጥን -->
    <div style="display: flex; justify-content: center; align-items: flex-end; gap: 40px; margin-bottom: 5px; max-width: 95%; margin-left: auto; margin-right: auto; padding-top: 10px;">
        
        <!-- 🚜 በግራ በኩል፦ T-72 ታንክ (መጠኑ ወደ 200px አድጓል፣ ወደ ታች ዝቅ ብሎ ከHome በላይ እንዲሆን margin-bottom ተሰጥቶታል) -->
        <div style="display: inline-block; margin-bottom: -15px;">
            <img src="/images/t72.jpg" style="width: 200px; height: 135px; object-fit: cover; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.6); border: 3px solid #fbbf24;" alt="T-72 Tank">
        </div>
        
        <!-- 🛡️ መሃል ላይ፦ የትምህርት ቤቱ ክብ ሎጎ (ከላይ ከፍ ብሎ እንዲቆይ የተደረገ) -->
        <div style="display: flex; align-items: center; margin-bottom: 25px;">
            <img src="/images/logo.jpg" width="130" style="border-radius: 50%; box-shadow: 0 6px 12px rgba(0,0,0,0.4);" alt="Logo">
        </div>
        
        <!-- 💥 በቀኝ በኩል፦ 155 ሚ.ሜ መድፍ (መጠኑ ወደ 200px አድጓል፣ ወደ ታች ዝቅ ብሎ ከAdmin በላይ እንዲሆን margin-bottom ተሰጥቶታል) -->
        <div style="display: inline-block; margin-bottom: -15px;">
            <img src="/images/medif155.jpg" style="width: 200px; height: 135px; object-fit: cover; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.5); border: 3px solid #fbbf24;" alt="155mm Artillery">
        </div>
        
    </div>

    <!-- 📌 ዋናው ርዕስ በአማርኛ በትልቅ እና በወርቃማ ቀለም -->
    <h1 style="font-size: 38px; font-weight: 800; color: #fbbf24; text-shadow: 2px 2px 6px rgba(0,0,0,0.9); margin: 5px 0 10px 0; letter-spacing: 1px;">
        ውጊያ ቴክኒክ ት/ቤት
    </h1>
    
    <!-- 📌 መፈክሩ ምንም ሳይነካ ልክ እንደነበረው በክብር -->
    <div style="display: inline-block; background: rgba(17, 24, 39, 0.65); padding: 12px 25px; border-left: 4px solid #fbbf24; border-right: 4px solid #fbbf24; border-radius: 4px; max-width: 90%; backdrop-filter: blur(5px); margin-bottom: 10px;">
        <span style="font-size: 16px; font-weight: bold; color: #fff; font-style: italic; text-shadow: 1px 1px 2px rgba(0,0,0,0.8);">
            "እናቅዳለን፤ እንጀምራለን፤ እናሰፋለን፤ በፍጥነት እና በጥራት እንፈጽማለን።"
        </span>
    </div>
</header>


<!-- 🌐 ንጹሕና ፍጹም ማራኪ ማውጫ (Navbar) -->
<nav>
    <a href="/">Home</a>
    <a href="/about.html">About</a>
    <a href="/history.html">History</a>
    <a href="https://t.me" target="_blank">Gallery 📸</a>
    <a href="https://t.me" target="_blank">News & Announcements 📰</a>
    <a href="/contact.html">Contact</a>
    <a href="/login.html">Admin</a>
</nav>

<!-- 🖼️ የትምህርት ቤቱ የጀርባ ምስል እና ጽሑፉ ፍጹም በሆነ ቁመት የተቀመጠበት የጀግናው ክፍል -->
<section class="hero">
    <div class="hero-content">
        <h1>Combat Technic School</h1>
        <p>Training Today's Soldiers for Tomorrow's Mission</p>
        <a href="/about.html" class="btn">Learn More</a>
        <a href="/contact.html" class="btn">Contact Us</a>
    </div>
</section>

<!-- 📰 የዜና ማሳያ ክፍል -->
<section class="container">
    <div class="card">
        <h2>📰 Latest News & Announcements</h2>
        <hr style="border:0; border-top:1px solid #eee; margin: 15px 0;">
        <% if (news && news.length > 0) { %>
            <% news.forEach(item => { %>
                <div style="margin-bottom: 25px; padding-bottom: 20px; border-bottom: 1px dashed #eee;">
                    <h3><%= item.title %></h3>
                    <p><%= item.description %></p>
                    <% if (item.image) { %>
                        <br>
                        <img src="<%= item.image %>" style="max-width:100%; height:auto; border-radius:8px; max-height:300px; object-fit:cover;">
                    <% } %>
                    <br>
                    <small style="color: #6b7280;">Posted on: <%= item.created_at %></small>
                </div>
            <% }) %>
        <% } else { %>
            <p align="center" style="color: #6b7280; font-style: italic;">No news or announcements available at the moment.</p>
        <% } %>
    </div>
</section>

<!-- 🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ ክፍል -->
<section class="container">
    <div class="card">
        <h2>🛡️ የውጊያ ቴክኒክ ት/ቤት ራዕይ እና ተልዕኮ</h2>
        <hr style="border:0; border-top:1px solid #eee; margin: 15px 0;">
        
        <h3>👁️ ራዕይ</h3>
        <p style="font-size: 16px; font-weight: 500;">
            በዘመኑ የጥምር ጦር ውጊያ ውስጥ ግዳጃቸውን በላቀ ደረጃ መወጣት የሚችሉ ብቁ የሜካናይዝድና ሞተራይዝድ ሙያተኞችን ማፍራት የሚችል ተመራጭ ት/ቤት ሆኖ ማየት።
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <h3>🎯 ተልዕኮ</h3>
        <p style="font-size: 16px; font-weight: 500;">
            በሜካናይዝድና በሞተራይዝድ ሙያ ግዳጃቸውን በብቃት መወጣት የሚችሉ ምድብተኞችን፣ የመሳሪያ አዛዦችን እና የመቶ አመራሮችን ማፍራት፣
        </p>
        
        <hr style="border: 0; border-top: 1px solid #eee; margin: 20px 0;">
        
        <h3>⭐ ዋና ዋና ተግባራት</h3>
        <ul style="list-style-type: none; padding-left: 0; font-size: 15px;">
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 በት/ቤቱ ሥርዓተ-ትምህርት መሰረት ቀጣይነት ያለውና ደረጃውን የጠበቀ የሜካናይዝድ የቴክኒክ ሥልጠና መስጠት፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 የፈጠራ ስራዎችን ማከናወንና በቴክኖሎጂ የተደገፈ ሥልጠና መስጠት፣</li>
            <li style="margin-bottom: 12px; padding-left: 20px; text-indent: -20px;">🔹 ለሠራዊታችን ክፍሎች ቀጥተኛ ሙያዊ ድጋፍ በመስጠት የሜካናይዝድ ክፍሎችን የማድረግ አቅም ማሳደግ፣</li>
            <li style="margin-bottom: 5px; padding-left: 20px; text-indent: -20px;">🔹 ከአካባቢው ማህበረሰብ ጋር በፀጥታና በልማት ስራዎች በትብብር መስራት፣</li>
        </ul>
    </div>
</section>

<!-- 📞 የኮንታክት መረጃ ሳጥን -->
<section class="container">
    <div class="card" style="max-width: 600px; margin: 0 auto;">
